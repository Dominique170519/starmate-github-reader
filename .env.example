# Persistent Neon PostgreSQL connection used only by server routes.
DATABASE_URL=
# GitHub OAuth App client id and secret. Callback: ${NEXT_PUBLIC_APP_URL}/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Random value with at least 32 characters for signing OAuth state and sessions.
AUTH_SECRET=
# Public deployed origin, for example https://starmate.example.com
NEXT_PUBLIC_APP_URL=
