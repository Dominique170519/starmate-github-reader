{
  "manifest_version": 3,
  "name": "星伴读 · GitHub 伴读侧栏",
  "version": "0.1.0",
  "description": "在 GitHub 页面内查看文章目录、搜索原文、记录笔记，并一键加入星伴读知识库。",
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}

